# Copy to .env and fill in for local development.
# Do NOT commit .env to git.

# ── Supabase ────────────────────────────────────────────────────────────────
# Names mirror the Supabase dashboard labels 1:1. The VITE_ prefix on the
# browser-facing two is a Vite requirement — without it, Vite won't bundle
# them into the client. The actual Supabase name after VITE_SUPABASE_ is
# the exact dashboard label.

# Supabase dashboard: "Project URL"  (Settings → API)
VITE_SUPABASE_PROJECT_URL=

# Supabase dashboard: "Publishable key"  (Settings → API)
# Safe to ship to the browser.
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase dashboard: "Secret key"  (Settings → API, click "Reveal")
# SERVER ONLY. Bypasses Row-Level Security. Never prefix with VITE_.
SUPABASE_SECRET_KEY=

# Supabase dashboard: "Session pooler" connection string
#   (Connect modal → Session pooler, or Settings → Database → Connection
#    string → Session)
# Port 5432 via pooler.supabase.com. IPv4-friendly (works from any network)
# AND supports DDL. Recommended for migrations + seed scripts unless your
# network has IPv6 egress.
SUPABASE_SESSION_POOLER_STRING=

# Supabase dashboard: "Direct Connection string"
#   (Connect modal → Direct connection)
# Port 5432 via db.<project>.supabase.co. IPv6-ONLY hostname — will fail
# DNS on IPv4-only networks. Only set if your network supports IPv6.
SUPABASE_DIRECT_CONNECTION_STRING=

# Supabase dashboard: "Transaction pooler" connection string
#   (Connect modal → Transaction pooler)
# Port 6543 via pooler.supabase.com. Used by the app runtime — required
# for serverless (Vercel). Cannot run DDL.
SUPABASE_TRANSACTION_POOLER_STRING=

# ── Auth (Supabase) ─────────────────────────────────────────────────────────

# Dev-only: synthesize a fake user when no real session is present.
# Gated to NODE_ENV != "production" in code. Unset or set to 0 for prod.
DEV_AUTH_BYPASS=1

# ── Stripe ──────────────────────────────────────────────────────────────────
# Use sk_test_... in dev, sk_live_... in prod. Webhook secret comes from
# Stripe CLI `stripe listen` or the dashboard endpoint settings.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLAYER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

# ── Resend (transactional email) ────────────────────────────────────────────
# Used by auth.sendMagicLink to deliver sign-in links, bypassing Supabase's
# free-tier email rate limit. Requires a verified sending domain in the
# Resend dashboard whose DNS the from-address in
# server/_core/sendMagicLinkEmail.ts resolves to.
RESEND_API_KEY=

# Optional overrides for the From address used by the auth emails. Default
# falls back to "LyricPro <noreply@playlyricpro.com>" — the legacy verified
# sender. Once a dedicated auth subdomain is verified in Resend
# (recommended: auth.playlyricpro.com), flip both values to e.g.
# "LyricPro <login@auth.playlyricpro.com>". Resend's deliverability guide
# explicitly recommends against `noreply@`, and isolating the auth subdomain
# keeps marketing/transactional reputations from poisoning each other.
#
# IMPORTANT: also turn off Click + Open tracking in the Resend dashboard for
# whichever domain is used here. Tracking rewrites the link to track.resend
# .com and trips spam filters / corporate URL scanners on auth mail.
MAGIC_LINK_FROM_ADDRESS=
PASSWORD_RESET_FROM_ADDRESS=

# ── Lyrics QA (verification + regeneration source-of-truth) ────────────────
# Used by scripts/verify-lyrics.mjs and the regeneration agents to fetch
# canonical lyrics for each song and check our generated variants against
# real source text. Lookup order: Musixmatch (licensed) → LRClib (free,
# no auth) → Genius (free dev key). Verification falls back gracefully if
# any one source has no record for a given track.
#
# Musixmatch: licensed lyrics provider. Required for production-quality
# QA. Get a key at https://developer.musixmatch.com/.
MUSIXMATCH_API_KEY=

# Genius: developer access token. Free; takes ~2 min at
# https://genius.com/api-clients. Used as fallback when Musixmatch /
# LRClib have no record.
GENIUS_ACCESS_TOKEN=

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowlist of origins that can call the API. Leave blank
# for same-origin only.
ALLOWED_ORIGINS=

# ── Optional: LLM / image generation ────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── Optional: analytics (Umami) ─────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Content read-path feature flag (Phase 5c) ───────────────────────────────
# Controls where the game runtime reads lyric variants from:
#
#   unset / 0 / false / anything else  → LEGACY path (default).
#       Reads songs.lyricVariants jsonb column. This is the safe default and
#       what production runs on until cutover is approved.
#
#   1 / true (case-insensitive)        → LAYER 3 path (Phase 5b schema).
#       Reads gameplay_items JOIN lyric_moments, filtered to qa_status='passed'
#       AND moment.approval_status='approved'. Order is gameplay_items.id ASC,
#       which matches the legacy variant index 1:1.
#
# Cutover plan (Phase 5e): set to "1" on Vercel; no code change required.
# Rollback: unset (or set to "0") and let the next cold start pick it up.
# DO NOT enable in production until Phase 5b verifier has reported zero drift
# for the live song corpus.
LYRIC_PRO_READ_FROM_LAYER3=

# ── User-ID hashing pepper (for song_displays.user_id_hashed) ──────────────
# 32-byte hex pepper used to one-way hash userId before storing in the
# song_displays.user_id_hashed column. Lets external publisher/aggregator
# reports include "unique user count" without exposing real user IDs.
# Generate locally with: openssl rand -hex 32
# NEVER ROTATE — rotation would break userId continuity across the audit log
# (same user would appear as different hashes across periods).
USER_HASH_PEPPER=

# ── LiveKit Cloud (Remote Live mode) ────────────────────────────────────────
# Get these from https://cloud.livekit.io → Project Settings → Keys.
# LIVEKIT_URL is the wss:// URL for your project (NOT the dashboard URL).
# Server-side secret. NEVER ship to client bundle.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

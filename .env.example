# Copy to .env and fill in for local development.
# Do NOT commit .env to git.

# ── Database (required for gameplay) ────────────────────────────────────────
# MySQL 8+. Drizzle manages the schema via `pnpm db:push`.
DATABASE_URL=mysql://user:password@host:3306/lyricpro

# ── Auth ────────────────────────────────────────────────────────────────────
# Manus OAuth portal. Leave blank in dev if DEV_AUTH_BYPASS=1.
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
JWT_SECRET=change-me-to-a-random-32-char-string

# Dev-only: synthesize a fake user when no OAuth session is present.
# Gated to NODE_ENV != "production" in code. Unset or set to 0 for prod.
DEV_AUTH_BYPASS=1

# ── Stripe ──────────────────────────────────────────────────────────────────
# Use sk_test_... in dev, sk_live_... in prod. Webhook secret comes from
# Stripe CLI `stripe listen` or the dashboard endpoint settings.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLAYER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowlist of origins that can call the API. Leave blank
# for same-origin only.
ALLOWED_ORIGINS=

# ── Optional: LLM / image generation ────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── Optional: analytics (Umami) ─────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

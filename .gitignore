.vercel

# Bundled Vercel serverless function output (generated by scripts/build-api.mjs).
# Source of truth lives in api-src/; api/ is fully regenerated per deploy.
# Exception: the two placeholder .mjs handlers below are committed so Vercel's
# detectBuilders phase sees api/*.mjs at clone time and registers @vercel/node
# functions. build-api.mjs overwrites them during the build with real bundles.
api/*
!api/trpc/
!api/stripe/
api/trpc/*
!api/trpc/\[trpc\].mjs
api/stripe/*
!api/stripe/webhook.mjs

# Capacitor build artifacts + local environment
ios/DerivedData/
ios/Pods/
ios/build/
android/.gradle/
android/.idea/
android/app/build/
android/build/
android/capacitor-cordova-android-plugins/build/
android/local.properties

# LLM rewrite checkpoint output (re-runnable, large)
scripts/regenerate-lyrics.checkpoint.json
scripts/resplit-lyrics-half.checkpoint.json
